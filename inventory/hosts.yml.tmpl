# Kubespray inventory template.
#
# `make` copies this to inventory/hosts.yml on first use; edit that copy, not
# this template. The hostnames, IPs, and node count MUST match the NODES array
# in the Vagrantfile (the IPs come from the DHCP reservations in
# k8s-lab-net.xml).
#
# Group layout below: all four nodes are control plane + worker (untainted),
# and three of them run etcd (an odd number is required for quorum).
all:
  hosts:
    k8s-1:
      ansible_host: 192.168.56.11
      ip: 192.168.56.11
      access_ip: 192.168.56.11
    k8s-2:
      ansible_host: 192.168.56.12
      ip: 192.168.56.12
      access_ip: 192.168.56.12
    k8s-3:
      ansible_host: 192.168.56.13
      ip: 192.168.56.13
      access_ip: 192.168.56.13
    k8s-4:
      ansible_host: 192.168.56.14
      ip: 192.168.56.14
      access_ip: 192.168.56.14
  vars:
    ansible_user: vagrant
    ansible_ssh_private_key_file: "{{ inventory_dir }}/../.vagrant/machines/{{ inventory_hostname }}/libvirt/private_key"
  children:
    # Control plane nodes. Taints are removed (see group_vars/k8s_cluster.yml)
    # so workloads also schedule here.
    kube_control_plane:
      hosts:
        k8s-1:
        k8s-2:
        k8s-3:
        k8s-4:
    kube_node:
      hosts:
        k8s-1:
        k8s-2:
        k8s-3:
        k8s-4:
    # etcd members — keep this an odd count (1, 3, 5, ...).
    etcd:
      hosts:
        k8s-1:
        k8s-2:
        k8s-3:
    k8s_cluster:
      children:
        kube_control_plane:
        kube_node:
    calico_rr:
      hosts: {}
